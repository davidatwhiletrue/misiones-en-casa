// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("child") // "admin" | "child"
  avatar    String?
  color     String?
  pin       String?
  xp        Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Missions assigned to this user
  assignedMissions Mission[] @relation("AssignedChild")
  // Missions where this user is the allowed child (null = all)
  allowedMissions  Mission[] @relation("AllowedChild")
  // Comments authored by this user
  comments         Comment[]
  // Streak progress entries for this user
  streakProgress   StreakProgress[]
}

model Mission {
  id          String    @id @default(cuid())
  title       String
  description String?  @db.Text
  reward      Float     @default(0)
  xpReward    Int       @default(0)
  category    String?
  difficulty  String?   @default("medium") // "easy" | "medium" | "hard"
  rarity      String?   @default("common") // "common" | "special" | "epic"
  status      String    @default("available") // "available" | "assigned" | "completed" | "approved" | "paid" | "rejected"
  repeatable  Boolean   @default(false)

  // The child who picked up this mission
  assignedChildId String?
  assignedChild   User?   @relation("AssignedChild", fields: [assignedChildId], references: [id])

  // If set, only this child can accept the mission (null = all children)
  allowedChildId String?
  allowedChild   User?   @relation("AllowedChild", fields: [allowedChildId], references: [id])

  // Mission type: "standard" or "streak"
  type        String    @default("standard")
  streakTarget Int?     // Number of consecutive days required for streak missions

  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?

  comments       Comment[]
  streakProgress StreakProgress[]
}

model StreakProgress {
  id              String    @id @default(cuid())
  missionId       String
  mission         Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  childId         String
  child           User      @relation(fields: [childId], references: [id])
  currentStreak   Int       @default(0)
  lastCheckInDate DateTime?
  status          String    @default("in_progress") // "in_progress" | "completed" | "approved" | "paid"
  completedAt     DateTime?
  approvedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  @@unique([missionId, childId])
}

model Comment {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  text      String   @db.Text
  createdAt DateTime @default(now())
}
